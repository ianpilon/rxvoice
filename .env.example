# Vapi credentials (dashboard.vapi.ai) — only needed by configure-complete-system.js,
# which creates/updates the RxVoice assistant. The runtime server doesn't use them.
VAPI_API_KEY=your_vapi_private_key_here
# Leave blank on first run — the configure script creates a new assistant and prints its ID.
VAPI_ASSISTANT_ID=

# Server port
PORT=3001
